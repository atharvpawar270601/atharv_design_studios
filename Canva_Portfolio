<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Design Portfolio | Showcasing My Creativity</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #1a1a1a;
            --accent: #00d2ff;
            --bg: #f4f7f6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background-color: var(--bg); color: #333; }

        header { background: white; padding: 20px 5%; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1); position: sticky; top: 0; z-index: 100; }
        .logo { font-size: 1.5rem; font-weight: 800; color: var(--primary); letter-spacing: -1px; }
        .logo span { color: var(--accent); }

        .hero { padding: 100px 5%; text-align: center; background: linear-gradient(135deg, #1a1a1a 0%, #333 100%); color: white; }
        .hero h1 { font-size: 3.5rem; margin-bottom: 15px; }
        .hero p { opacity: 0.8; font-size: 1.2rem; margin-bottom: 30px; }

        .section { padding: 80px 5%; }
        .section-title { text-align: center; margin-bottom: 50px; }
        .section-title h2 { font-size: 2.5rem; color: var(--primary); position: relative; display: inline-block; }
        .section-title h2::after { content: ''; width: 50%; height: 4px; background: var(--accent); position: absolute; bottom: -10px; left: 25%; }

        /* The Gallery Grid */
        .portfolio-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
        .project-card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: 0.3s; }
        .project-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        
        .img-container { width: 100%; height: 250px; overflow: hidden; background: #eee; }
        .img-container img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
        .project-card:hover img { scale: 1.1; }

        .project-info { padding: 20px; }
        .project-info h3 { margin-bottom: 8px; color: var(--primary); }
        .project-info p { font-size: 0.9rem; color: #666; }

        .contact-footer { background: var(--primary); color: white; padding: 60px 5%; text-align: center; }
        .btn-whatsapp { background: #25d366; color: white; padding: 15px 35px; text-decoration: none; border-radius: 50px; font-weight: bold; display: inline-block; margin-top: 20px; font-size: 1.1rem; }
        
        @media (max-width: 768px) { .hero h1 { font-size: 2.5rem; } }
    </style>
</head>
<body>

<header>
    <div class="logo">CREATIVE<span>PORTFOLIO</span></div>
</header>

<section class="hero">
    <h1>Design that Drives Results.</h1>
    <p>From Professional Letterheads to Viral YouTube Thumbnails.</p>
    <a href="#contact" class="btn-whatsapp" style="background: var(--accent);">View My Price List</a>
</section>

<section class="section">
    <div class="section-title">
        <h2>My Work Gallery</h2>
    </div>
    
    <div class="portfolio-grid">
        <!-- Project 1: Menus -->
        <div class="project-card">
            <div class="img-container">
                <img src="YOUR_IMAGE_LINK_HERE" alt="Restaurant Menu Design">
            </div>
            <div class="project-info">
                <h3>Restaurant & Hotel Menus</h3>
                <p>Custom layouts designed to improve customer experience and appetite.</p>
            </div>
        </div>

        <!-- Project 2: Social Media -->
        <div class="project-card">
            <div class="img-container">
                <img src="YOUR_IMAGE_LINK_HERE" alt="YouTube Thumbnail">
            </div>
            <div class="project-info">
                <h3>High-CTR Thumbnails</h3>
                <p>Eye-catching designs for YouTube and Instagram to boost your clicks.</p>
            </div>
        </div>

        <!-- Project 3: Corporate -->
        <div class="project-card">
            <div class="img-container">
                <img src="YOUR_IMAGE_LINK_HERE" alt="Visiting Card Design">
            </div>
            <div class="project-info">
                <h3>Corporate Branding</h3>
                <p>Professional Visiting Cards, Letterheads, and Official Marksheets.</p>
            </div>
        </div>

        <!-- Project 4: Events -->
        <div class="project-card">
            <div class="img-container">
                <img src="YOUR_IMAGE_LINK_HERE" alt="Invitation Card Design">
            </div>
            <div class="project-info">
                <h3>Events & Invitations</h3>
                <p>Creative banners and cards for programs like Kavya Sandhya.</p>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="contact-footer">
    <h2>Ready to grow your business?</h2>
    <p>Available for projects in Amravati and online globally.</p>
    <!-- REPLACE THE NUMBER BELOW WITH YOUR ACTUAL WHATSAPP NUMBER -->
    <a href="https://wa.me/91XXXXXXXXXX" class="btn-whatsapp">
        <i class="fab fa-whatsapp"></i> Chat on WhatsApp to Order
    </a>
    <p style="margin-top: 20px; opacity: 0.6;">Email: yourname@email.com</p>
</section>

</body>
</html>
